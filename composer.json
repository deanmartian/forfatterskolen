{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=7.2",
        "anhskohbo/no-captcha": "^3.0",
        "barryvdh/laravel-dompdf": "^0.8.2",
        "barryvdh/laravel-ide-helper": "^2.4",
        "barryvdh/laravel-translation-manager": "^0.5.0",
        "firebase/php-jwt": "^5.0",
        "guzzlehttp/guzzle": "^6.5",
        "laravel/framework": "^6.0",
        "laravel/helpers": "^1.5",
        "laravel/socialite": "^4.0",
        "laravel/tinker": "^2.0",
        "league/fractal": "^0.17.0",
        "league/omnipay": "^3.0",
        "maatwebsite/excel": "~3.1.38",
        "omnipay/paypal": "^3.0",
        "phpoffice/phpword": "^0.14.0",
        "spatie/flysystem-dropbox": "*",
        "sudiptpa/paypal-ipn": "^2.0",
        "sveaekonomi/webpay": "^3.13",
        "symfony/event-dispatcher": "~4.0",
        "symfony/polyfill-iconv": "^1.8",
        "teodortalov/citrix": "^1.2",
        "unisharp/laravel-filemanager": "^2.3",
        "van-ons/laraberg": "^1.1",
        "laravel/ui": "^2.0"
    },
    "require-dev": {
        "fzaninotto/faker": "~1.4",
        "mockery/mockery": "0.9.*",
        "phpunit/phpunit": "^8.5",
        "filp/whoops": "~2.0"
    },
    "autoload": {
        "classmap": [
            "database"
        ],
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postInstall",
            "php artisan optimize"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "php artisan optimize",
            "php artisan ide-helper:generate"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
